# Linux user/group ID — run `id` to find yours
PUID=1000
PGID=1000

# Timezone — https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Chicago

# Directory where config.yml and state.db will be stored
CONFIG_DIR=./config

# Set to false when running over plain HTTP (e.g., local dev without HTTPS).
# Default is true — always use true behind a reverse proxy with TLS.
SECURE_COOKIES=false
